{
  "expo": {
    "name": "Agendamento EECJVS",
    "slug": "agendamento-eecjvs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "br.edu.eecjvs.agendamento",
      "buildNumber": "5",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Para foto de perfil",
        "NSPhotoLibraryUsageDescription": "Para selecionar foto de perfil",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "package": "br.edu.eecjvs.agendamento",
      "versionCode": 2,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2563eb"
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/42487ea5-0489-4d65-a43e-9daa7c9a3279"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "agendamento-eecjvs",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "42487ea5-0489-4d65-a43e-9daa7c9a3279"
      }
    },
    "owner": "adilsoneju"
  }
}
